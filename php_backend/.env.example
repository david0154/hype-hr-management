# ── Firebase ──────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=hype-hr-your-project-id
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_STORAGE_BUCKET=hype-hr-your-project-id.appspot.com

# ── API Secret (protect your PHP endpoints) ───────────────────────────────────
API_SECRET=change-this-to-a-strong-random-secret

# ── SMS Service (OPTIONAL — leave blank to disable) ───────────────────────────
# Supported values: twilio | fast2sms | msg91 | (leave blank = disabled)
SMS_PROVIDER=

# --- Fast2SMS (India, cheapest) ---
# SMS_API_KEY=your_fast2sms_api_key

# --- Twilio ---
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_AUTH_TOKEN=your_auth_token
# SMS_FROM_NUMBER=+1xxxxxxxxxx
# SMS_API_KEY=your_auth_token

# --- MSG91 (India) ---
# SMS_PROVIDER=msg91
# SMS_API_KEY=your_msg91_authkey
# SMS_SENDER_ID=HYPEHR
