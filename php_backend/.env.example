# \u2500\u2500 Firebase \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
FIREBASE_PROJECT_ID=hype-hr-your-project-id
FIREBASE_STORAGE_BUCKET=hype-hr-your-project-id.appspot.com
FIREBASE_API_KEY=your_firebase_web_api_key_here
FIREBASE_SERVICE_JSON=/var/www/html/php_backend/firebase-service-account.json

# \u2500\u2500 API Secret (protect /webhook.php and other endpoints) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
API_SECRET=change-this-to-a-strong-random-secret

# \u2500\u2500 SMTP Email (optional \u2014 leave blank to disable) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_FROM_NAME=Hype HR Management

# \u2500\u2500 SMS Service (optional \u2014 choose ONE provider) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
SMS_ENABLED=false
# Supported values: fast2sms | msg91 | twilio | (leave blank = auto-detect from API key)
SMS_PROVIDER=

# SMS_API_KEY is used by:
#   Fast2SMS  \u2192 your Fast2SMS API key
#   MSG91     \u2192 your MSG91 auth key
#   Twilio    \u2192 set SMS_AUTH_TOKEN instead (or use SMS_API_KEY for auth token)
SMS_API_KEY=

# --- Fast2SMS (India \u2014 cheapest, recommended) ---
# SMS_PROVIDER=fast2sms
# SMS_API_KEY=your_fast2sms_api_key_here

# --- MSG91 (India) ---
# SMS_PROVIDER=msg91
# SMS_API_KEY=your_msg91_authkey_here
# SMS_SENDER_ID=HYPEHR

# --- Twilio (International) ---
# SMS_PROVIDER=twilio
# SMS_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMS_AUTH_TOKEN=your_twilio_auth_token
# SMS_FROM_NUMBER=+1xxxxxxxxxx
