<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView android:id="@+id/tvLogDate"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:textSize="13sp" android:textColor="@color/colorText"
            android:textStyle="bold"/>

        <TextView android:id="@+id/tvLogAction"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="0.6"
            android:textSize="14sp" android:textStyle="bold"
            android:gravity="center"/>

        <TextView android:id="@+id/tvLogLocation"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp" android:textColor="@color/colorTextMuted"
            android:gravity="end"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
