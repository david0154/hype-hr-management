<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/colorBackground">

    <TextView
        android:id="@+id/tvEmpName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/colorText"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your PIN to continue"
        android:textSize="14sp"
        android:textColor="@color/colorTextMuted"
        android:layout_marginBottom="32dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/label_pin"
        app:passwordToggleEnabled="true"
        android:layout_marginBottom="24dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:maxLength="6"
            android:imeOptions="actionDone"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnterPin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_enter_pin"
        app:cornerRadius="12dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvLoginWithPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Use Username & Password instead"
        android:textColor="@color/colorPrimary"
        android:textSize="13sp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>
